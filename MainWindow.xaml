<Window x:Class="Scalpel.MainWindow" Icon="pack://application:,,,/Resources/scalpel.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scalpel"
        mc:Ignorable="d"
        Title="Scalpel" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BgDark}"
        FontFamily="{DynamicResource FontUI}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Brush keys come from Application.Resources (theme dicts) via DynamicResource.
             Only non-colour styles live here. -->

        <!-- Toolbar button -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontIcon}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarButtonAccent" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
        </Style>
        <Style x:Key="ToolbarButtonDanger" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Foreground" Value="{DynamicResource DangerRed}"/>
        </Style>
        <Style x:Key="ToolbarToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontIcon}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontIcon}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeCloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Foreground" Value="{DynamicResource DangerRed}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerRed}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar, ContextMenu, MenuItem, Separator styles moved to Themes/_Shared.xaml -->

        <!-- ======================================================== -->
        <!-- Dark ComboBox (zoom dropdown)                           -->
        <!-- ======================================================== -->

        <!-- Toggle button used inside the ComboBox template -->
        <Style x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem inside the dark popup -->
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsStatus}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource AccentDim}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource AccentDim}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The ComboBox itself -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource BgControl}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsStatus}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Clickable area / border -->
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Selected item text (non-editable mode) -->
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="7,0,0,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"/>
                                    <!-- Editable text box (shown when IsEditable=True) -->
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="5,0,0,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimary}"
                                             FontFamily="{DynamicResource FontUI}"
                                             FontSize="{DynamicResource FsStatus}"
                                             Typography.NumeralAlignment="Tabular"
                                             VerticalAlignment="Center"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             Visibility="Hidden"
                                             Focusable="True"
                                             SelectionBrush="{DynamicResource AccentDim}"
                                             SelectionTextBrush="{DynamicResource Accent}"
                                             CaretBrush="{DynamicResource Accent}"/>
                                    <!-- Chevron arrow -->
                                    <TextBlock Grid.Column="1"
                                               Text="{StaticResource Ico_Chevron}"
                                               FontFamily="{DynamicResource FontIcon}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                    <!-- Invisible toggle over the whole control -->
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  Style="{StaticResource DarkComboToggle}"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                              RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Grid>
                            </Border>
                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   Placement="Bottom">
                                <Border Background="{DynamicResource BgPanel}"
                                        BorderBrush="{DynamicResource BorderDim}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="2"
                                        MinWidth="{Binding ActualWidth,
                                                   RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="220">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Page list styles -->
        <Style x:Key="PageListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource BgSidebar}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDim}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar tab buttons (PAGES / OUTLINES) -->
        <Style x:Key="SidebarTabBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsSidebarLabel}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="2,2,8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TreeView for PDF outline/bookmarks -->
        <Style x:Key="OutlineTreeStyle" TargetType="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsBody}"/>
        </Style>
        <Style x:Key="OutlineItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsBody}"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="2,3"/>
        </Style>

        <!-- General-purpose themed text button -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsBody}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings panel radio button -->
        <Style x:Key="ThemeRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontUI}"/>
            <Setter Property="FontSize" Value="{DynamicResource FsBody}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Title bar + Quick Access Toolbar -->
        <Border x:Name="TitleBarBorder" Grid.Row="0" Background="{DynamicResource ChromeBg}" BorderBrush="{DynamicResource BorderDim}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="Scalpel" FontFamily="{DynamicResource FontUI}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource ChromeText}" VerticalAlignment="Center"/>
                    <TextBlock Text="PDF" FontFamily="{DynamicResource FontUI}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource AccentLogo}" VerticalAlignment="Center"/>
                    <!-- QAT divider -->
                    <Border Width="1" Height="18" Background="{DynamicResource BorderDim}" Margin="12,0,8,0"/>
                    <!-- Quick Access Toolbar: persistent file actions (right-click Open/Save for more) -->
                    <Button Style="{StaticResource QatButton}" Click="Open_Click" Content="{StaticResource Ico_Open}" ToolTip="{DynamicResource Str_TT_Open}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Str_Lbl_Open}" Click="Open_Click"/>
                                <MenuItem Header="{DynamicResource Str_Lbl_New}" Click="New_Click"/>
                                <MenuItem x:Name="CloseFileMenuItem" Header="{DynamicResource Str_Lbl_CloseFile}" Click="CloseFile_Click" IsEnabled="False"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="SaveAsBtn" Style="{StaticResource QatButton}" Click="Save_Click" Content="{StaticResource Ico_Save}" ToolTip="{DynamicResource Str_TT_Save}" Margin="1,0,0,0">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Str_Lbl_SaveAs}" Click="SaveAs_Click"/>
                                <MenuItem Header="{DynamicResource Str_Lbl_SaveFlattened}" Click="SaveFlattened_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource QatButton}" Click="Print_Click" Content="{StaticResource Ico_Print}" ToolTip="{DynamicResource Str_TT_Print}" Margin="1,0,0,0"/>
                    <Button Style="{StaticResource QatButton}" Click="Undo_Click" Content="{StaticResource Ico_Undo}" ToolTip="{DynamicResource Str_TT_UndoLast}" Margin="1,0,0,0"/>
                </StackPanel>
                <TextBlock Text="" x:Name="FileNameLabel" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource ChromeTextDim}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsBody}"
                           Typography.NumeralAlignment="Tabular"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{StaticResource Ico_Min}" Click="MinimizeBtn_Click" Style="{StaticResource ChromeButton}"/>
                    <Button Content="{StaticResource Ico_Max}" Click="MaximizeBtn_Click" Style="{StaticResource ChromeButton}"/>
                    <Button Content="{StaticResource Ico_WinClose}" Click="CloseBtn_Click" Style="{StaticResource ChromeCloseButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Ribbon tab strip — mode tabs (left) connect into the band below; utilities (right) -->
        <Border x:Name="RibbonTabBorder" Grid.Row="1" Background="{DynamicResource RibbonBg}" BorderBrush="{DynamicResource BorderDim}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="12,4,12,0">
                <!-- RadioButtons (grouped) so clicking the active tab can't deselect it; RibbonTab targets ToggleButton (RadioButton's base). -->
                <RadioButton x:Name="ModeViewTab"  GroupName="AppModeTabs" Style="{StaticResource RibbonTab}" Content="{DynamicResource Str_Mode_View}"  Checked="ModeTab_Checked" Tag="View"/>
                <RadioButton x:Name="ModeEditTab"  GroupName="AppModeTabs" Style="{StaticResource RibbonTab}" Content="{DynamicResource Str_Mode_Edit}"  Checked="ModeTab_Checked" Tag="Edit"  Margin="2,0,0,0"/>
                <RadioButton x:Name="ModePagesTab" GroupName="AppModeTabs" Style="{StaticResource RibbonTab}" Content="{DynamicResource Str_Mode_Pages}" Checked="ModeTab_Checked" Tag="Pages" Margin="2,0,0,0"/>
                <RadioButton x:Name="ModeSignTab"  GroupName="AppModeTabs" Style="{StaticResource RibbonTab}" Content="{DynamicResource Str_Mode_Sign}"  Checked="ModeTab_Checked" Tag="Sign"  Margin="2,0,0,0"/>

                <!-- Right-aligned utilities -->
                <Button DockPanel.Dock="Right" Style="{StaticResource StudioIconButton}" Click="SettingsBtn_Click"
                        Content="{StaticResource Ico_Settings}" FontFamily="{DynamicResource FontIcon}" ToolTip="{DynamicResource Str_TT_Settings}" Margin="0,2,0,2"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource StudioIconButton}" Click="OpenSearch_Click"
                        Content="{StaticResource Ico_Search}" FontFamily="{DynamicResource FontIcon}" ToolTip="{DynamicResource Str_TT_Search}" Margin="0,2,4,2"/>
                <Button x:Name="ModeWhatsNewTab" DockPanel.Dock="Right" Style="{StaticResource StudioModeTabButton}"
                        Content="{DynamicResource Str_Mode_WhatsNew}" Click="WhatsNewTab_Click" Margin="0,2,2,2"/>
                <Button x:Name="ModeAboutTab" DockPanel.Dock="Right" Style="{StaticResource StudioModeTabButton}"
                        Content="{DynamicResource Str_Mode_About}" Click="AboutTab_Click" Margin="0,2,2,2"/>
                <!-- Tools menu (document-level operations) -->
                <Button x:Name="ToolsMenuBtn" DockPanel.Dock="Right" Style="{StaticResource StudioModeTabButton}" Click="FileMenu_Click" ToolTip="{DynamicResource Str_TT_Tools}" Margin="0,2,2,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="16" Text="{StaticResource Ico_Settings}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Str_Lbl_Tools}" VerticalAlignment="Center"/>
                        <TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="13" Text="{StaticResource Ico_Chevron}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{DynamicResource Str_Tool_Numbering}" Click="ToolsNumbering_Click"/>
                            <MenuItem Header="{DynamicResource Str_Tool_Compress}" Click="ToolsCompress_Click"/>
                            <MenuItem Header="{DynamicResource Str_Tool_Ocr}" Click="ToolsOcr_Click"/>
                            <MenuItem Header="{DynamicResource Str_Tool_DocInfo}" Click="ToolsDocumentInfo_Click"/>
                            <Separator/>
                            <MenuItem Header="{DynamicResource Str_Tool_Redact}" Click="ToolsRedact_Click"/>
                            <MenuItem Header="{DynamicResource Str_Tool_Protect}" Click="ToolsProtect_Click"/>
                            <MenuItem Header="{DynamicResource Str_Tool_Sanitize}" Click="ToolsSanitize_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </DockPanel>
        </Border>

        <!-- Ribbon band (contextual command groups; one mode panel visible at a time) -->
        <Border x:Name="RibbonBandBorder" Grid.Row="2" Background="{DynamicResource RibbonBand}" BorderBrush="{DynamicResource BorderDim}" BorderThickness="0,0,0,1" Padding="10,8,10,6">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Focusable="False">
            <Grid HorizontalAlignment="Left">
              <!-- View panel: Layout group + Display group -->
              <StackPanel x:Name="ModePanelView" Orientation="Horizontal" Visibility="Visible">
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="ViewSingleBtn" Style="{StaticResource RibbonToggle}" Click="ViewSingle_Click" ToolTip="{DynamicResource Str_View_Single}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Single}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_View_Single}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ViewContinuousBtn" Style="{StaticResource RibbonToggle}" Click="ViewContinuous_Click" ToolTip="{DynamicResource Str_View_Continuous}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Continuous}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_View_Continuous}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ViewTwoPageBtn" Style="{StaticResource RibbonToggle}" Click="ViewTwoPage_Click" ToolTip="{DynamicResource Str_View_TwoPage}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_TwoPage}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_View_TwoPage}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ViewGridBtn" Style="{StaticResource RibbonToggle}" Click="ViewGrid_Click" ToolTip="{DynamicResource Str_View_Grid}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Grid}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_View_Grid}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </ToggleButton>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_Layout}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource BorderDim}" Margin="6,4,6,4"/>
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <Button x:Name="ViewFitBtn" Style="{StaticResource RibbonButton}" Click="ViewFit_Click" ToolTip="{DynamicResource Str_Lbl_Fit}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Fit}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Fit}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Click="RotatePagesToolbar_Click" ToolTip="{DynamicResource Str_TT_Rotate}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Rotate}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Rotate}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_Display}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
              </StackPanel>

              <!-- Edit panel: Tools group + History group -->
              <StackPanel x:Name="ModePanelEdit" Orientation="Horizontal" Visibility="Collapsed">
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <Button x:Name="ToolSelectBtn" Style="{StaticResource RibbonButton}" Click="ToolSelect_Click" ToolTip="{DynamicResource Str_TT_SelectTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Select}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Select}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="ToolTextBtn" Style="{StaticResource RibbonButton}" Click="ToolText_Click" ToolTip="{DynamicResource Str_TT_TextTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Text}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Text}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="ToolHighlightBtn" Style="{StaticResource RibbonButton}" Click="ToolHighlight_Click" ToolTip="{DynamicResource Str_TT_HighlightTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Highlight}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Highlight}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="ToolDrawBtn" Style="{StaticResource RibbonButton}" Click="ToolDraw_Click" ToolTip="{DynamicResource Str_TT_DrawTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Draw}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Draw}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="ToolLineBtn" Style="{StaticResource RibbonButton}" Click="ToolLine_Click" ToolTip="{DynamicResource Str_TT_LineTool}">
                      <StackPanel>
                        <Line X1="3" Y1="20" X2="20" Y2="3" StrokeThickness="2.2" Width="23" Height="23"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Str_Lbl_Line}" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                    <Button x:Name="ToolImageBtn" Style="{StaticResource RibbonButton}" Click="ToolImage_Click" ToolTip="{DynamicResource Str_TT_ImageTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Image}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Image}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="ToolCropBtn" Style="{StaticResource RibbonButton}" Click="ToolCrop_Click" ToolTip="{DynamicResource Str_TT_CropTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Crop}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Crop}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_Tools}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource BorderDim}" Margin="6,4,6,4"/>
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RibbonButton}" Click="Undo_Click" ToolTip="{DynamicResource Str_TT_UndoLast}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Undo}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Undo}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Foreground="{DynamicResource DangerRed}" Click="ClearAnnotations_Click" ToolTip="{DynamicResource Str_TT_ClearAnnotations}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Clear}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Clear}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_History}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
              </StackPanel>

              <!-- Pages panel: Organize group + Arrange group -->
              <StackPanel x:Name="ModePanelPages" Orientation="Horizontal" Visibility="Collapsed">
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RibbonButton}" Click="Merge_Click" ToolTip="{DynamicResource Str_TT_MergePDFs}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Merge}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Merge}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Click="Split_Click" ToolTip="{DynamicResource Str_TT_ExtractPages}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Extract}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Extract}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Click="InsertBlankPage_Click" ToolTip="{DynamicResource Str_TT_InsertPage}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_InsertPage}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_InsertPage}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Foreground="{DynamicResource DangerRed}" Click="Delete_Click" ToolTip="{DynamicResource Str_TT_DeletePages}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Delete}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Delete}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_Organize}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource BorderDim}" Margin="6,4,6,4"/>
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RibbonButton}" Click="MoveUp_Click" ToolTip="{DynamicResource Str_TT_MovePageUp}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_MoveUp}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_MoveUp}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Click="MoveDown_Click" ToolTip="{DynamicResource Str_TT_MovePageDown}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_MoveDown}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_MoveDown}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonButton}" Click="RotatePagesToolbar_Click" ToolTip="{DynamicResource Str_TT_Rotate}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Rotate}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Rotate}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_Arrange}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
              </StackPanel>

              <!-- Sign panel: Signature group -->
              <StackPanel x:Name="ModePanelSign" Orientation="Horizontal" Visibility="Collapsed">
                <StackPanel Margin="2,0">
                  <StackPanel Orientation="Horizontal">
                    <Button x:Name="ToolSignatureBtn" Style="{StaticResource RibbonButton}" Click="ToolSignature_Click" ToolTip="{DynamicResource Str_TT_SignatureTool}">
                      <StackPanel><TextBlock FontFamily="{DynamicResource FontIcon}" FontSize="23" Text="{StaticResource Ico_Signature}" HorizontalAlignment="Center"/><TextBlock Text="{DynamicResource Str_Lbl_Signature}" Margin="0,5,0,0" HorizontalAlignment="Center"/></StackPanel>
                    </Button>
                  </StackPanel>
                  <TextBlock Text="{StaticResource Grp_Signature}" FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}" FontWeight="SemiBold" Foreground="{DynamicResource RibbonGroupLabel}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="3" x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <!-- SidebarCol never collapses to 0 — it shrinks to 24px (the toggle strip width). -->
                <ColumnDefinition x:Name="SidebarCol" Width="180" MinWidth="24" MaxWidth="260"/>
                <!-- Dedicated drag handle column — keeps the splitter independent of the sidebar content -->
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar column: inner grid splits content from permanent toggle strip -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>        <!-- page list content -->
                    <ColumnDefinition Width="24"/>       <!-- toggle strip — always visible -->
                </Grid.ColumnDefinitions>

                <!-- Page list content (hidden when collapsed) -->
                <Border x:Name="SidebarBorder" Grid.Column="0"
                        Background="{DynamicResource BgSidebar}"
                        BorderBrush="{DynamicResource BorderDim}" BorderThickness="0,0,0,0">
                    <DockPanel>
                        <!-- Sticky header — lives outside the ScrollViewer so it never scrolls away -->
                        <!-- Tab row: PAGES (left) | OUTLINES (right) -->
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="10,6,8,0">
                            <Button x:Name="SidebarPagesTab" Content="{DynamicResource Str_TabPages}"
                                    DockPanel.Dock="Left"
                                    Style="{StaticResource SidebarTabBtn}"
                                    Foreground="{DynamicResource Accent}"
                                    Click="SidebarPagesTab_Click"/>
                            <Button x:Name="SidebarOutlinesTab" Content="{DynamicResource Str_TabOutlines}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource SidebarTabBtn}"
                                    IsEnabled="False"
                                    Click="SidebarOutlinesTab_Click"/>
                        </DockPanel>
                        <!-- Page controls row (hidden in outlines mode) -->
                        <DockPanel x:Name="PageControlsRow" DockPanel.Dock="Top" LastChildFill="False" Margin="12,2,8,4">
                            <TextBox x:Name="PageJumpBox" DockPanel.Dock="Left"
                                     Width="30" Height="20" VerticalAlignment="Center"
                                     TextAlignment="Center" VerticalContentAlignment="Center"
                                     FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}"
                                     Typography.NumeralAlignment="Tabular"
                                     Background="{DynamicResource BgControl}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderDim}" BorderThickness="1"
                                     CaretBrush="{DynamicResource Accent}"
                                     SelectionBrush="{DynamicResource AccentDim}"
                                     IsEnabled="False"
                                     FocusVisualStyle="{x:Null}"
                                     KeyDown="PageJumpBox_KeyDown"
                                     GotFocus="PageJumpBox_GotFocus"
                                     ToolTip="{DynamicResource Str_TT_GoToPage}"
                                     Margin="0,0,2,0">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderDim}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            <TextBlock x:Name="PageTotalLabel" DockPanel.Dock="Left"
                                       Text="/ –" VerticalAlignment="Center"
                                       FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsSidebarLabel}"
                                       Typography.NumeralAlignment="Tabular"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="2,0,0,0"/>
                        </DockPanel><!-- /PageControlsRow -->
                        <!-- Scrollable page list (virtualized) -->
                        <ListBox x:Name="PageList" Style="{StaticResource PageListBox}"
                                 BorderThickness="0" SelectionMode="Extended"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="PageList_SelectionChanged"
                                 AllowDrop="True" Drop="PageList_Drop" DragOver="PageList_DragOver"
                                 PreviewMouseLeftButtonDown="PageList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="PageList_PreviewMouseMove"
                                 MouseRightButtonUp="PageList_MouseRightButtonUp">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:PageThumbnailVm}">
                                    <StackPanel HorizontalAlignment="Center" Margin="0,2,0,2">
                                        <Border x:Name="ThumbBorder"
                                                Background="White"
                                                BorderBrush="{DynamicResource BgDark}"
                                                BorderThickness="1">
                                            <Image Source="{Binding Thumbnail}"
                                                   Width="140"
                                                   Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontFamily="{DynamicResource FontUI}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                            <Setter TargetName="ThumbBorder" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <!-- Outline/bookmark tree (visible when OUTLINES tab is active) -->
                        <ScrollViewer x:Name="OutlineScrollViewer"
                                      Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TreeView x:Name="OutlineTree"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Style="{StaticResource OutlineTreeStyle}"
                                      ItemContainerStyle="{StaticResource OutlineItemStyle}"
                                      Padding="4,2"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Toggle strip — 24px wide vertical icon bar -->
                <Border Grid.Column="1"
                        Background="{DynamicResource BgSidebar}"
                        BorderThickness="0">
                    <Grid>
                        <!-- Collapse/expand arrow at top -->
                        <Button x:Name="SidebarToggleBtn"
                                Content="{StaticResource Ico_ChevronLeft}" ToolTip="{DynamicResource Str_TT_CollapseSidebar}"
                                Style="{StaticResource StudioIconButton}"
                                Width="24" Height="24" Padding="0"
                                VerticalAlignment="Top" Margin="0,6,0,0"
                                Click="SidebarToggle_Click"/>
                        <!-- Settings and help icons pinned to bottom -->
                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,6">
                            <Button Click="ShortcutHelp_Click"
                                    Style="{StaticResource StudioIconButton}"
                                    Content="{StaticResource Ico_Shortcuts}"
                                    ToolTip="{DynamicResource Str_TT_KeyboardShortcuts}"
                                    Width="24" Height="24" Padding="0" Margin="0,0,0,6"/>
                            <Button x:Name="SettingsBtn"
                                    Click="SettingsBtn_Click"
                                    Style="{StaticResource StudioIconButton}"
                                    Content="{StaticResource Ico_Settings}"
                                    ToolTip="{DynamicResource Str_TT_Settings}"
                                    Width="24" Height="24" Padding="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Drag-to-resize splitter (only active in OUTLINES mode) -->
            <GridSplitter x:Name="SidebarSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderDim}"
                          Cursor="SizeWE"
                          IsEnabled="False"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}">
                            <!-- three-dot grip, centred vertically -->
                            <ItemsControl VerticalAlignment="Center" HorizontalAlignment="Center"
                                          IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <Ellipse Width="3" Height="3" Margin="0,2" Fill="{DynamicResource BgDragHandle}"/>
                                <Ellipse Width="3" Height="3" Margin="0,2" Fill="{DynamicResource BgDragHandle}"/>
                                <Ellipse Width="3" Height="3" Margin="0,2" Fill="{DynamicResource BgDragHandle}"/>
                            </ItemsControl>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Preview area -->
            <Border Grid.Column="2" Background="{DynamicResource BgCanvas}">
                <Grid>
                    <!-- Drop zone -->
                    <Border x:Name="DropZone" Background="Transparent"
                            AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver"
                            MouseLeftButtonDown="DropZone_Click">
                        <Border BorderBrush="{DynamicResource BorderDim}" BorderThickness="2"
                                CornerRadius="8" Margin="40" Padding="40"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="Transparent" Style="{x:Null}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Drop PDF here" FontFamily="{DynamicResource FontUI}" FontSize="20"
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="or click to browse" FontFamily="{DynamicResource FontUI}" FontSize="13"
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- PDF page with annotation overlay. FlowDirection is pinned LeftToRight so
                         a right-to-left UI locale (Hebrew/Arabic) never mirrors the document
                         coordinate space — otherwise canvas clicks and edit-box placement land
                         on the wrong side. The PDF page coordinate system is always LTR. -->
                    <ScrollViewer x:Name="PagePreviewPanel" Visibility="Collapsed"
                                  FlowDirection="LeftToRight"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent"
                                  PreviewMouseWheel="PagePreview_PreviewMouseWheel"
                                  SizeChanged="PagePreviewPanel_SizeChanged"
                                  PreviewMouseDown="PagePreviewPanel_PreviewMouseDown"
                                  PreviewMouseMove="PagePreviewPanel_PreviewMouseMove"
                                  PreviewMouseUp="PagePreviewPanel_PreviewMouseUp"
                                  AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver">
                        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Padding="12">
                            <Grid x:Name="PageContentGrid">
                                <Grid.LayoutTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Grid.LayoutTransform>
                                <WrapPanel x:Name="PageContentPanel" Orientation="Horizontal">
                                    <!-- Primary page (always present) -->
                                    <Border Background="White" VerticalAlignment="Top" Margin="0,0,12,12">
                                        <Grid>
                                            <Image x:Name="PageImage" RenderOptions.BitmapScalingMode="HighQuality" Stretch="None"/>
                                            <Canvas x:Name="AnnotationCanvas" Background="Transparent" ClipToBounds="True"
                                                    PreviewMouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                                    MouseMove="Canvas_MouseMove"
                                                    PreviewMouseLeftButtonUp="Canvas_MouseLeftButtonUp"/>
                                        </Grid>
                                    </Border>
                                    <!-- Additional pages rendered dynamically in code-behind -->
                                </WrapPanel>
                                <!-- Continuous scroll panel - shown in Continuous view mode -->
                                <StackPanel x:Name="ContinuousPanel"
                                            HorizontalAlignment="Center"
                                            Orientation="Vertical"
                                            Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border x:Name="StatusBarBorder" Grid.Row="4" Background="{DynamicResource ChromeBg}" BorderBrush="{DynamicResource BorderDim}" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <TextBlock x:Name="StatusText" Text="{DynamicResource Str_Ready}"
                           Foreground="{DynamicResource ChromeTextDim}"
                           FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsStatus}"
                           Typography.NumeralAlignment="Tabular"
                           VerticalAlignment="Center"/>
                <!-- Portable mode indicator (hidden when installed) -->
                <StackPanel x:Name="PortableBadge" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str_Portable}" Foreground="{DynamicResource ChromeTextDim}"
                               FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsStatus}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button x:Name="InstallBtn" Content="{DynamicResource Str_InstallBtn}"
                            Click="Install_Click"
                            FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsStatus}"
                            Foreground="{DynamicResource Accent}"
                            Background="Transparent"
                            BorderThickness="1" BorderBrush="{DynamicResource AccentDim}"
                            Padding="8,1" Cursor="Hand"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentDim}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="VersionLabel" Text="v1.5.1"
                               Foreground="{DynamicResource ChromeTextDim}" FontFamily="{DynamicResource FontUI}"
                               FontSize="{DynamicResource FsStatus}" Typography.NumeralAlignment="Tabular"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Cursor="Hand" ToolTip="{DynamicResource Str_TT_About}"
                               MouseLeftButtonDown="VersionLabel_MouseLeftButtonDown"/>
                    <TextBlock FontSize="{DynamicResource FsStatus}" VerticalAlignment="Center"
                               FontFamily="{DynamicResource FontUI}">
                        <Run Text="&#x00A9; 2026 " Foreground="{DynamicResource ChromeTextDim}"/>
                        <Hyperlink NavigateUri="https://github.com/blakazulu/ScalpelPDF"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource ChromeTextDim}" TextDecorations="None">
                            <Run Text="Liraz Amir"/>
                        </Hyperlink>
                    </TextBlock>
                    <!-- Zoom cluster (relocated from the old toolbar) -->
                    <Border Width="1" Height="16" Background="{DynamicResource BorderDim}" Margin="14,0,12,0"/>
                    <Button x:Name="ZoomOutBtn" Style="{StaticResource QatButton}" Width="26" Height="26" FontSize="15" Click="ZoomOut_Click" Content="{StaticResource Ico_ZoomOut}" ToolTip="{DynamicResource Str_TT_ZoomOut}"/>
                    <ComboBox x:Name="ZoomBox" Width="92" Height="24" VerticalAlignment="Center" Margin="3,0"
                              IsEditable="True" IsReadOnly="True"
                              Style="{StaticResource DarkComboBox}"
                              SelectionChanged="ZoomBox_SelectionChanged" ToolTip="{DynamicResource Str_TT_ZoomLevel}">
                        <ComboBoxItem Tag="fitpage" Content="{DynamicResource Str_Zoom_FitPage}"/>
                        <ComboBoxItem Tag="fitwidth" Content="{DynamicResource Str_Zoom_FitWidth}"/>
                        <ComboBoxItem Tag="0.5">50%</ComboBoxItem>
                        <ComboBoxItem Tag="0.75">75%</ComboBoxItem>
                        <ComboBoxItem Tag="1.0" IsSelected="True">100%</ComboBoxItem>
                        <ComboBoxItem Tag="1.25">125%</ComboBoxItem>
                        <ComboBoxItem Tag="1.5">150%</ComboBoxItem>
                        <ComboBoxItem Tag="2.0">200%</ComboBoxItem>
                    </ComboBox>
                    <Button x:Name="ZoomInBtn" Style="{StaticResource QatButton}" Width="26" Height="26" FontSize="15" Click="ZoomIn_Click" Content="{StaticResource Ico_ZoomIn}" ToolTip="{DynamicResource Str_TT_ZoomIn}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Settings overlay -->
        <Grid x:Name="SettingsOverlay"
              Grid.RowSpan="5"
              Panel.ZIndex="9999"
              Visibility="Collapsed"
              Background="Transparent"
              MouseLeftButtonDown="SettingsOverlay_MouseLeftButtonDown">
            <!-- Bounds grid: stretches within the overlay minus margins so the card's MaxHeight
                 can bind to it (no converter needed) and the card scrolls on short screens. -->
            <Grid x:Name="SettingsBounds"
                  HorizontalAlignment="Left" VerticalAlignment="Stretch"
                  Margin="8,48,0,36">
            <Border Style="{StaticResource StudioOverlayCard}"
                    Padding="20,16,20,20"
                    VerticalAlignment="Bottom"
                    MinWidth="220"
                    MaxHeight="{Binding ActualHeight, ElementName=SettingsBounds}"
                    MouseLeftButtonDown="SettingsOverlayCard_MouseLeftButtonDown">
                <DockPanel>
                    <!-- Sticky title: stays put while the settings list scrolls below it. -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Str_Settings}"
                                   FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsDialogTitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Click="SettingsOverlayClose_Click"
                                Style="{StaticResource StudioIconButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}"
                                Content="{StaticResource Ico_WinClose}"/>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                      <StackPanel>
                    <ToggleButton x:Name="ThemeHeaderToggle" Content="{DynamicResource Str_Theme}"
                                  Style="{StaticResource SettingsSectionToggle}" Margin="0,0,0,2"/>
                    <StackPanel Margin="0,0,0,4"
                                Visibility="{Binding IsChecked, ElementName=ThemeHeaderToggle, Converter={StaticResource BoolToVis}}">
                    <RadioButton x:Name="ThemeDarkRadio"
                                 Content="{DynamicResource Str_Theme_Dark}"
                                 GroupName="ThemeGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="ThemeDarkRadio_Checked"/>
                    <RadioButton x:Name="ThemeLightRadio"
                                 Content="{DynamicResource Str_Theme_Light}"
                                 GroupName="ThemeGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="ThemeLightRadio_Checked"/>
                    <RadioButton x:Name="ThemeHCRadio"
                                 Content="{DynamicResource Str_Theme_HighContrast}"
                                 GroupName="ThemeGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="ThemeHCRadio_Checked"/>
                    </StackPanel>

                    <ToggleButton x:Name="AccentHeaderToggle" Content="{DynamicResource Str_Accent}"
                                  Style="{StaticResource SettingsSectionToggle}"/>
                    <StackPanel Margin="0,0,0,4"
                                Visibility="{Binding IsChecked, ElementName=AccentHeaderToggle, Converter={StaticResource BoolToVis}}">
                    <RadioButton x:Name="AccentAmberRadio"
                                 Content="{DynamicResource Str_Accent_Amber}"
                                 GroupName="AccentGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="AccentAmberRadio_Checked"/>
                    <RadioButton x:Name="AccentRedRadio"
                                 Content="{DynamicResource Str_Accent_Red}"
                                 GroupName="AccentGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="AccentRedRadio_Checked"/>
                    <RadioButton x:Name="AccentGreenRadio"
                                 Content="{DynamicResource Str_Accent_Green}"
                                 GroupName="AccentGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="AccentGreenRadio_Checked"/>
                    <RadioButton x:Name="AccentCyanRadio"
                                 Content="{DynamicResource Str_Accent_Cyan}"
                                 GroupName="AccentGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="AccentCyanRadio_Checked"/>
                    </StackPanel>

                    <ToggleButton x:Name="LangHeaderToggle" Content="{DynamicResource Str_Language}"
                                  Style="{StaticResource SettingsSectionToggle}"/>
                    <StackPanel Margin="0,0,0,4"
                                Visibility="{Binding IsChecked, ElementName=LangHeaderToggle, Converter={StaticResource BoolToVis}}">
                    <RadioButton x:Name="LangEnRadio"
                                 Content="{DynamicResource Str_Lang_English}"
                                 GroupName="LangGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="LangEnRadio_Checked"/>
                    <RadioButton x:Name="LangEsRadio"
                                 Content="{DynamicResource Str_Lang_Spanish}"
                                 GroupName="LangGroup"
                                 Style="{StaticResource ThemeRadio}"
                                 Checked="LangEsRadio_Checked"/>
                     <RadioButton x:Name="LangZhTWRadio"
                                  Content="{DynamicResource Str_Lang_Traditional_Chinese}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangZhTWRadio_Checked"/>
                     <RadioButton x:Name="LangZhCNRadio"
                                  Content="{DynamicResource Str_Lang_Simple_Chinese}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangZhCNRadio_Checked"/>
                     <RadioButton x:Name="LangBnRadio"
                                  Content="{DynamicResource Str_Lang_Bengali}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangBnRadio_Checked"/>
                     <RadioButton x:Name="LangTrRadio"
                                  Content="{DynamicResource Str_Lang_Turkish}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangTrRadio_Checked"/>
                     <RadioButton x:Name="LangHeRadio"
                                  Content="{DynamicResource Str_Lang_Hebrew}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangHeRadio_Checked"/>
                     <RadioButton x:Name="LangArRadio"
                                  Content="{DynamicResource Str_Lang_Arabic}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangArRadio_Checked"/>
                     <RadioButton x:Name="LangRuRadio"
                                  Content="{DynamicResource Str_Lang_Russian}"
                                  GroupName="LangGroup"
                                  Style="{StaticResource ThemeRadio}"
                                  Checked="LangRuRadio_Checked"/>
                    </StackPanel>

                    <CheckBox x:Name="UpdateCheckToggle"
                              Foreground="{DynamicResource TextPrimary}"
                              Margin="0,8,0,0"
                              Click="UpdateCheckToggle_Click">
                        <TextBlock Text="{DynamicResource Str_Settings_CheckUpdates}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontFamily="{DynamicResource FontUI}" FontSize="12"/>
                    </CheckBox>

                    <TextBlock Text="{DynamicResource Str_Settings_Diagnostics}" Foreground="{DynamicResource Accent}"
                               FontFamily="{DynamicResource FontUI}" FontSize="11" FontWeight="SemiBold"
                               Margin="0,12,0,4"/>
                    <TextBlock Text="{DynamicResource Str_Log_Description}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontFamily="{DynamicResource FontUI}" FontSize="11"
                               TextWrapping="Wrap" MaxWidth="240"
                               HorizontalAlignment="Left" Margin="0,0,0,8"/>
                    <CheckBox x:Name="LogEnabledCheck"
                              Foreground="{DynamicResource TextPrimary}"
                              Margin="0,0,0,8"
                              Checked="LogEnabledCheck_Changed"
                              Unchecked="LogEnabledCheck_Changed">
                        <TextBlock Text="{DynamicResource Str_Log_Enable}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontFamily="{DynamicResource FontUI}" FontSize="12"/>
                    </CheckBox>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="OpenLogsBtn"
                                Content="{DynamicResource Str_Log_OpenFolder}"
                                Style="{StaticResource StudioToolButton}"
                                Margin="0,0,8,0"
                                Click="OpenLogsBtn_Click"/>
                        <Button x:Name="ClearLogsBtn"
                                Content="{DynamicResource Str_Log_Clear}"
                                Style="{StaticResource StudioToolButton}"
                                Click="ClearLogsBtn_Click"/>
                    </StackPanel>
                      </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            </Grid>
        </Grid>

        <!-- Keyboard shortcut overlay — neutral dark dim regardless of theme -->
        <Grid x:Name="ShortcutOverlay"
              Grid.RowSpan="5"
              Panel.ZIndex="10000"
              Visibility="Collapsed"
              Background="#88000000"
              MouseLeftButtonDown="ShortcutOverlay_MouseLeftButtonDown">
            <Border Style="{StaticResource StudioOverlayCard}"
                    Padding="28,16,28,22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="480"
                    MaxWidth="640"
                    MouseLeftButtonDown="ShortcutOverlayCard_MouseLeftButtonDown">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Str_KS_Title}"
                                   FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsDialogTitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Click="ShortcutOverlayClose_Click"
                                Style="{StaticResource StudioIconButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}"
                                Content="{StaticResource Ico_WinClose}"/>
                    </Grid>

                    <!-- Column layout -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Str_KS_File}" Foreground="{DynamicResource Accent}"
                                       FontFamily="{DynamicResource FontUI}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+O" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_Open}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+W" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_CloseFile}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+N" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_NewBlank}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+Shift+S" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_SaveAs}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,0"><TextBlock Text="Ctrl+P" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_Print}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>

                            <TextBlock Text="{DynamicResource Str_KS_Navigation}" Foreground="{DynamicResource Accent}"
                                       FontFamily="{DynamicResource FontUI}" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="&#x2190; / &#x2192; or &#x2191; / &#x2193;" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_PrevNext}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+Scroll" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_ZoomCursor}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+= / Ctrl+-" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_ZoomInOut}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+0" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_ResetZoom}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Middle drag" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_PanView}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,0"><TextBlock Text="Space + drag" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_PanView}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Str_KS_Editing}" Foreground="{DynamicResource Accent}"
                                       FontFamily="{DynamicResource FontUI}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+Z" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_Undo}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Delete" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_DeleteAnnot}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Enter / Escape" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_ConfirmCancel}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <TextBlock Text="{DynamicResource Str_KS_SearchSelect}" Foreground="{DynamicResource Accent}"
                                       FontFamily="{DynamicResource FontUI}" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+F" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_Find}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Enter / Shift+Enter" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_NextPrevResult}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,4"><TextBlock Text="Ctrl+A" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_SelectAll}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <DockPanel Margin="0,0,0,0"><TextBlock Text="Ctrl+C" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_CopyText}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                            <TextBlock Text="{DynamicResource Str_KS_Help}" Foreground="{DynamicResource Accent}"
                                       FontFamily="{DynamicResource FontUI}" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <DockPanel Margin="0,0,0,0"><TextBlock Text="Ctrl+?" FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource TextSecondary}" Width="120"/><TextBlock Text="{DynamicResource Str_KS_ThisList}" FontSize="{DynamicResource Str_KS_FontSize}" Foreground="{DynamicResource TextPrimary}"/></DockPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
        <!-- About overlay -->
        <Grid x:Name="AboutOverlay"
              Grid.RowSpan="5"
              Panel.ZIndex="10001"
              Visibility="Collapsed"
              Background="#88000000"
              MouseLeftButtonDown="AboutOverlay_MouseLeftButtonDown">
            <Border Style="{StaticResource StudioOverlayCard}"
                    Padding="28,20,28,22"
                    VerticalAlignment="Center"
                    Width="560"
                    MouseLeftButtonDown="AboutOverlayCard_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Margin="0,0,20,0">
                    <!-- Logo (populated in code-behind with hyperlink) -->
                    <TextBlock x:Name="AboutLogoBlock"
                               FontSize="22" FontWeight="Bold"
                               Margin="0,0,0,4" Cursor="Hand"/>
                    <!-- Tagline (populated in code-behind with hyperlinks) -->
                    <TextBlock x:Name="AboutTaglineBlock"
                               FontSize="11" Margin="0,0,0,16"/>
                    <!-- Info card -->
                    <Border Background="{DynamicResource BgPanel}"
                            CornerRadius="4"
                            Padding="14,12,14,4">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_Version}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock x:Name="AboutVersionBlock"
                                           FontFamily="{DynamicResource FontUI}" FontSize="12"
                                           Foreground="{DynamicResource Accent}"
                                           Cursor="Hand"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_Author}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock FontFamily="{DynamicResource FontUI}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" Text="Liraz Amir"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_Repository}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock FontFamily="{DynamicResource FontUI}" FontSize="12">
                                    <Hyperlink NavigateUri="https://github.com/blakazulu/ScalpelPDF"
                                               RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="{DynamicResource Accent}" TextDecorations="None">
                                        <Run Text="github.com/blakazulu/ScalpelPDF"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_License}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock FontFamily="{DynamicResource FontUI}" FontSize="12">
                                    <Hyperlink NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html"
                                               RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="{DynamicResource Accent}" TextDecorations="None">
                                        <Run Text="GPLv3"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_Publisher}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock x:Name="AboutPublisherBlock"
                                           FontFamily="{DynamicResource FontUI}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_Thumbprint}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock x:Name="AboutThumbprintBlock"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{DynamicResource Str_About_ExeSha}" Foreground="{DynamicResource TextDim}"
                                           FontFamily="{DynamicResource FontUI}" FontSize="11" Margin="0,0,0,2"/>
                                <TextBlock x:Name="AboutSha256Block"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                    <!-- X close button overlaid at top-right - no vertical space consumed -->
                    <Button Click="AboutOverlayClose_Click"
                            Style="{StaticResource StudioIconButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            FocusVisualStyle="{x:Null}"
                            Content="{StaticResource Ico_WinClose}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- What's New (changelog) overlay -->
        <Grid x:Name="WhatsNewOverlay"
              Grid.RowSpan="5"
              Panel.ZIndex="10001"
              Visibility="Collapsed"
              Background="#88000000"
              MouseLeftButtonDown="WhatsNewOverlay_MouseLeftButtonDown">
            <Border Style="{StaticResource StudioOverlayCard}"
                    Padding="28,20,28,22"
                    VerticalAlignment="Center"
                    Width="560" MaxHeight="600"
                    MouseLeftButtonDown="WhatsNewOverlayCard_MouseLeftButtonDown">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="{DynamicResource Str_WhatsNew_Title}"
                                   FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsDialogTitle}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Click="WhatsNewOverlayClose_Click"
                                Style="{StaticResource StudioIconButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}"
                                Content="{StaticResource Ico_WinClose}"/>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="WhatsNewList"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Update-available overlay -->
        <Grid x:Name="UpdateOverlay"
              Grid.RowSpan="5"
              Panel.ZIndex="10002"
              Visibility="Collapsed"
              Background="#88000000"
              MouseLeftButtonDown="UpdateOverlay_MouseLeftButtonDown">
            <Border Style="{StaticResource StudioOverlayCard}"
                    Padding="28,22,28,22"
                    VerticalAlignment="Center"
                    Width="480" MaxHeight="520"
                    MouseLeftButtonDown="UpdateOverlayCard_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Str_Update_Title}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="UpdateBodyText"
                               Margin="0,10,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <StackPanel x:Name="UpdateNotesPanel" Margin="0,12,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="{DynamicResource Str_Update_Later}"
                                Style="{StaticResource StudioToolButton}"
                                MinWidth="92" Margin="0,0,10,0"
                                Click="UpdateLater_Click"/>
                        <Button Content="{DynamicResource Str_Update_Get}"
                                Style="{StaticResource StudioPrimaryButton}"
                                MinWidth="120"
                                Click="UpdateGet_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Font-missing toast -->
        <Grid x:Name="ToastHost"
              Grid.RowSpan="5"
              Panel.ZIndex="10000"
              Visibility="Collapsed"
              Background="{x:Null}">
            <Border Style="{StaticResource StudioOverlayCard}"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,16,0,0" Padding="16,10"
                    MaxWidth="520">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastText"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimary}"
                               FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsBody}"/>
                    <Button x:Name="ToastCopyBtn"
                            Content="{DynamicResource Str_FontMissing_CopyName}"
                            Click="ToastCopyBtn_Click"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource StudioToolButton}"
                            Foreground="{DynamicResource Accent}"
                            FontFamily="{DynamicResource FontUI}" FontSize="{DynamicResource FsBody}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Film grain overlay - main content area only -->
        <Border x:Name="GrainOverlay"
                Grid.Row="3"
                IsHitTestVisible="False"
                Opacity="0.15"
                Panel.ZIndex="9999">
            <Border.Background>
                <ImageBrush x:Name="GrainBrush"
                            TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,256,256"
                            Stretch="None"/>
            </Border.Background>
        </Border>
    </Grid>
</Window>
