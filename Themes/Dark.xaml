<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- KillerTools dark/green theme -->
    <SolidColorBrush x:Key="BgDark"         Color="#333333" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgPanel"        Color="#3a3a3a" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgHover"        Color="#404040" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgSidebar"      Color="#222222" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgModal"        Color="#1e1e1e" po:Freeze="True"/>
    <SolidColorBrush x:Key="BorderDim"      Color="#2e2e2e" po:Freeze="True"/>
    <SolidColorBrush x:Key="Accent"         Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentLogo"     Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentBorder"   Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"      Color="#0d2a18" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextPrimary"    Color="#e0e0e0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="#888888" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextDim"        Color="#6a6a6a" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextFooter"     Color="#6a6a6a" po:Freeze="True"/>
    <SolidColorBrush x:Key="DangerRed"      Color="#ef4444" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgDragHandle"   Color="#555555" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb"  Color="#551ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgOverlay"      Color="#BB000000" po:Freeze="True"/>
    <sys:Double x:Key="GrainOpacity">0.15</sys:Double>

    <SolidColorBrush x:Key="BgCanvas"                                                       Color="#333333" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#0d2a18" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#0d2a18" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1ea54c" po:Freeze="True"/>

</ResourceDictionary>
